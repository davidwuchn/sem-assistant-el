# OpenRouter API Configuration (required)
# Get your API key from https://openrouter.ai/keys
OPENROUTER_KEY=
OPENROUTER_MODEL=
# Optional weak-tier model used for Pass 1 :task: normalization.
# If unset/empty, weak tier falls back to OPENROUTER_MODEL.
OPENROUTER_WEAK_MODEL=

# RSS Digest Configuration (optional, defaults shown)
RSS_MAX_ENTRIES_PER_FEED=10
RSS_MAX_INPUT_CHARS=199000

# Daemon watchdog configuration (optional, defaults shown)
SEM_WATCHDOG_PROBE_TIMEOUT_SEC=45
SEM_WATCHDOG_STARTUP_GRACE_SEC=180

# WebDAV Configuration (optional, defaults shown)
# WEBDAV_DOMAIN must match the Let's Encrypt certificate domain
WEBDAV_DOMAIN=example.com
WEBDAV_USERNAME=orgzly
WEBDAV_PASSWORD=changeme

# Certbot Configuration (production only; enable with: docker compose --profile certbot up -d)
# CERTBOT_EMAIL is required by Let's Encrypt for certificate issuance notices
CERTBOT_EMAIL=admin@example.com
# true = Let's Encrypt staging CA (safe for first validation), false = production CA
CERTBOT_STAGING=true
# Interval between renewal checks in the certbot container
CERTBOT_RENEW_INTERVAL=12h
