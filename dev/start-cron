#!/bin/sh
# Start cron daemon and keep container running in Docker
# Cron runs in background, emacs runs as daemon, tail keeps foreground alive

# Set correct permissions on cron directories (cron requires this)
chmod -R go-w /etc/cron.d /etc/crontabs

if [ -z "${CLIENT_TIMEZONE:-}" ]; then
  echo "SEM: STARTUP ERROR: CLIENT_TIMEZONE is not set"
  exit 1
fi

cron_tmp="$(mktemp)"
{
  printf 'CRON_TZ=%s\n' "$CLIENT_TIMEZONE"
  printf 'TZ=%s\n' "$CLIENT_TIMEZONE"
  awk '
    /^[[:space:]]*$/ { print; next }
    /^[[:space:]]*#/ { print; next }
    /^[A-Za-z_][A-Za-z0-9_]*=/ { next }
    {
      if (NF >= 7 && $6 == "root") {
        printf "%s %s %s %s %s", $1, $2, $3, $4, $5
        for (i = 7; i <= NF; i++) {
          printf " %s", $i
        }
        printf "\n"
      } else {
        print
      }
    }
  ' /etc/cron.d/sem-cron
} > "$cron_tmp"
mv "$cron_tmp" /etc/crontabs/root
chmod 0600 /etc/crontabs/root

# Start cron daemon in background
if command -v service >/dev/null 2>&1; then
  service cron start
else
  crond
fi

# Start emacs daemon in background with explicit socket name.
# Use Eask so package dependencies are available on load-path.
eask emacs --bg-daemon=sem-server --load=/app/elisp/init.el

# Gate keepalive handoff on readiness success.
ready_max_attempts="${SEM_DAEMON_READY_MAX_ATTEMPTS:-30}"
ready_sleep_sec="${SEM_DAEMON_READY_SLEEP_SEC:-2}"
readiness_expr="(if (and (fboundp 'sem-init-readiness-probe) (sem-init-readiness-probe)) t nil)"
attempt=0
ready=0

while [ "$attempt" -lt "$ready_max_attempts" ]; do
  attempt=$((attempt + 1))
  probe_output="$(emacsclient -s sem-server --eval "$readiness_expr" 2>/dev/null || true)"
  if [ "$probe_output" = "t" ]; then
    ready=1
    break
  fi
  echo "SEM: startup readiness pending (${attempt}/${ready_max_attempts})"
  if [ "$attempt" -lt "$ready_max_attempts" ]; then
    sleep "$ready_sleep_sec"
  fi
done

if [ "$ready" -ne 1 ]; then
  echo "SEM: startup readiness failed after ${ready_max_attempts} attempts"
  exit 1
fi

# Keep container alive by tailing the log file
# This runs in foreground and keeps PID 1 alive
tail -F /var/log/cron.log
