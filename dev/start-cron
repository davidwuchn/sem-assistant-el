#!/bin/sh
# Start cron daemon and keep container running in Docker
# Cron runs in background, emacs runs as daemon, tail keeps foreground alive

# Set correct permissions on cron directories (cron requires this)
chmod -R go-w /etc/cron.d

# Start cron daemon in background
if command -v service >/dev/null 2>&1; then
  service cron start
else
  crond
fi

# Start emacs daemon in background with explicit socket name.
# Use Eask so package dependencies are available on load-path.
eask emacs --bg-daemon=sem-server --load=/app/elisp/init.el

# Keep container alive by tailing the log file
# This runs in foreground and keeps PID 1 alive
tail -F /var/log/cron.log
